VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_API_BASE_URL=""                 # Optional: Railway API origin when UI and API are split

# Optional feature flags
VITE_ENABLE_BASE_WALLET="false"      # Coinbase/OnchainKit wallet features (disable to avoid SES/lockdown issues)

# Optional - only needed for specific features
VITE_ONCHAINKIT_API_KEY=""           # Base/Coinbase wallet integration
VITE_DISCORD_CLIENT_ID=""            # Discord Activity mode
VITE_WORLD_ID_APP_ID=""              # World ID verification

# Railway server runtime
OPENAI_API_KEY=""                    # Preferred provider for /api/chat
OPENAI_MODEL="gpt-4.1-mini"          # Optional: override the default chat model
AI_GATEWAY_API_KEY=""                # Alternative provider path for the AI SDK
AI_MODEL=""                          # Example: openai/gpt-4.1-mini when using AI Gateway
SUPABASE_URL=""                      # Railway runtime source of truth; also injected into the frontend at request time
SUPABASE_PUBLISHABLE_KEY=""          # Railway runtime source of truth; also injected into the frontend at request time

